{
  "name": "pulse-rewards",
  "version": "1.0.0",
  "private": true,
  "description": "Pulse Rewards — blockchain loyalty platform on Stellar",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon --watch backend/src --ext ts,js --exec ts-node backend/src/index.ts",
    "dev:frontend": "next dev frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "next build frontend",
    "start:backend": "node backend/dist/index.js",
    "start:frontend": "next start frontend",
    "lint": "eslint . --ext .ts,.tsx,.js --max-warnings 0",
    "lint:frontend": "eslint frontend/src --ext .ts,.tsx --max-warnings 0",
    "type-check": "tsc -p backend/tsconfig.json --noEmit",
    "type-check:frontend": "tsc -p frontend/tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "test:backend": "jest --testPathPattern=backend --coverage",
    "test:frontend": "jest --testPathPattern=frontend --coverage",
    "test:ci": "jest --ci --coverage --coverageReporters=lcov",
    "db:migrate": "node -r ts-node/register backend/src/db/migrate.ts",
    "db:migrate:rollback": "node -r ts-node/register backend/src/db/migrate.ts rollback"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "next": "14.2.3",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.5",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.39",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.4",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/backend/src/$1"
    },
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "backend/src/**/*.ts",
      "!backend/src/**/*.d.ts",
      "!backend/src/index.ts"
    ]
  }
}
